# Discord Configuration (required)
# Get these from https://discord.com/developers/applications
token=your_discord_bot_token
clientId=your_application_id
guildId=your_server_id

# Privileged user IDs (comma-separated, for admin commands)
privilegedIds=123456789,987654321

# Anthropic (required for ai command — Claude Haiku)
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# AI system prompt (optional, customizes bot personality)
AI_SYSTEM_PROMPT=You are generbot, a concise and direct AI assistant.

# xAI Grok (required for ai-image command)
# Get from https://console.x.ai/
GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxx

# Prompts directory (optional, defaults to ./prompts/)
# PROMPTS_DIR=/home/gener/prompts

# RapidAPI (required for commodities commands and flight tracking)
# Get from https://rapidapi.com/alphavantage/api/alpha-vantage
rapidApiKey=xxxxxxxxxxxxxxxxxxxx

# Brave Search (required for imagesearch and food commands)
# Get from https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=xxxxxxxxxxxxxxxxxxxx

# Unsplash (required for random image command)
# Get from https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx

# MongoDB (optional, for database features)
MONGO_DB_USER=your_mongo_user
MONGO_DB_PASSWORD=your_mongo_password
DB_NAME=generbot

# Runtime
PORT=6776
LOG_LEVEL=info
NODE_ENV=development
